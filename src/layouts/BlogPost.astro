---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import BaseHead from '@components/BaseHead.astro';
import TableOfContents from '@components/docs/TableOfContents.astro';
import ShareLinks from '@components/blog/ShareLinks.astro';
import SearchDialog from '@components/SearchDialog.astro';
import '../styles/global.css';

interface TocItem {
  id: string;
  text: string;
  depth: number;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  tags?: string[];
  image?: string;
  headings: TocItem[];
  slug: string;
  wordCount?: number;
}

const { title, description, date, author, tags = [], image, headings, slug, wordCount = 0 } = Astro.props;

const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const postUrl = `https://swe-squad.dev/blog/${slug}`;

const tocItems = headings
  .filter((h) => h.depth >= 2 && h.depth <= 4)
  .map((h) => ({ id: h.id, text: h.text, depth: h.depth }));

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} | SWE-Squad Blog`} description={description} image={image} type="article">
      <script is:inline>
        (function() {
          const theme = localStorage.getItem('theme');
          if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        })();
      </script>
      <meta data-pagefind-meta="title" content={title} />
      <meta data-pagefind-meta="description" content={description} />
    </BaseHead>
    <style is:global>
      .blog-layout {
        display: grid;
        grid-template-columns: 1fr var(--toc-width);
        max-width: 56rem;
        margin: 0 auto;
        min-height: 100vh;
      }

      .blog-main {
        padding: 2rem 2.5rem;
        min-width: 0;
      }

      .blog-toc {
        padding: 2rem 1rem;
        border-left: 1px solid var(--color-border);
      }

      .blog-header {
        margin-bottom: 2rem;
      }

      .blog-breadcrumb {
        margin-bottom: 1rem;
      }

      .blog-breadcrumb a {
        color: var(--color-text-secondary);
        text-decoration: none;
        font-size: 0.8125rem;
        transition: color 0.15s;
      }

      .blog-breadcrumb a:hover {
        color: var(--color-accent);
      }

      .blog-title {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.2;
        margin: 0 0 0.75rem;
        color: var(--color-text-primary);
      }

      .blog-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        margin-bottom: 0.75rem;
      }

      .blog-meta-item {
        display: flex;
        align-items: center;
        gap: 0.375rem;
      }

      .blog-tags {
        display: flex;
        gap: 0.375rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
      }

      .blog-tag {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        background: var(--color-bg-hover);
        border: 1px solid var(--color-border);
        border-radius: 0.25rem;
        font-size: 0.75rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
      }

      .blog-tag:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
      }

      .blog-hero-image {
        width: 100%;
        max-height: 20rem;
        object-fit: cover;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
      }

      .blog-main h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2rem 0 0.75rem;
        padding-bottom: 0.375rem;
        border-bottom: 1px solid var(--color-border);
      }

      .blog-main h3 {
        font-size: 1.25rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
      }

      .blog-main p {
        margin: 0.75rem 0;
      }

      .blog-main code {
        font-size: 0.875em;
        padding: 0.125rem 0.375rem;
        background: var(--color-bg-hover);
        border-radius: 0.25rem;
      }

      .blog-main pre {
        padding: 1rem;
        background: #1e1e2e;
        color: #cdd6f4;
        border-radius: 0.5rem;
        overflow-x: auto;
      }

      .blog-main pre code {
        padding: 0;
        background: none;
        color: inherit;
      }

      .blog-main table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
      }

      .blog-main th,
      .blog-main td {
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--color-border);
        text-align: left;
      }

      .blog-main th {
        background: var(--color-bg-sidebar);
        font-weight: 600;
      }

      .blog-main ol,
      .blog-main ul {
        padding-left: 1.5rem;
      }

      .blog-footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--color-border);
      }

      @media (max-width: 1023px) {
        .blog-layout {
          grid-template-columns: 1fr;
        }

        .blog-main {
          padding: 2rem 1rem;
        }

        .blog-toc {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <div class="blog-layout">
      <main class="blog-main" data-pagefind-body>
        <div class="blog-header">
          <div class="blog-breadcrumb">
            <a href="/blog">&larr; Blog</a>
          </div>
          <h1 class="blog-title">{title}</h1>
          <div class="blog-meta">
            <span class="blog-meta-item">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 1.5a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11zm-.25 1.75v3.5l2.5 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {formattedDate}
            </span>
            <span class="blog-meta-item">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1.5a2.75 2.75 0 0 0-2.75 2.75v1h-.5A1.25 1.25 0 0 0 3.5 6.5v5.75c0 .69.56 1.25 1.25 1.25h6.5c.69 0 1.25-.56 1.25-1.25V6.5a1.25 1.25 0 0 0-1.25-1.25h-.5v-1A2.75 2.75 0 0 0 8 1.5zm0 1.25c.83 0 1.5.67 1.5 1.5v1h-3v-1c0-.83.67-1.5 1.5-1.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {author}
            </span>
            <span class="blog-meta-item">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 4h12v8H2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                <path d="M5 4V2.5M11 4V2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              {readingTime} min read
            </span>
          </div>
          {tags.length > 0 && (
            <div class="blog-tags">
              {tags.map((tag) => (
                <a href={`/blog?tag=${tag}`} class="blog-tag">{tag}</a>
              ))}
            </div>
          )}
          {image && (
            <img src={image} alt={title} class="blog-hero-image" width={1200} height={630} loading="eager" fetchpriority="high" />
          )}
        </div>
        <slot />
        <div class="blog-footer">
          <ShareLinks title={title} url={postUrl} />
        </div>
      </main>
      <aside class="blog-toc">
        {tocItems.length > 0 && <TableOfContents items={tocItems} />}
      </aside>
    </div>
    <SearchDialog />
    <Footer />
  </body>
</html>
