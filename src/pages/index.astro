---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import TrustBar from '../components/landing/TrustBar.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import FeatureGrid from '../components/landing/FeatureGrid.astro';
---

<BaseLayout title="SWE-Squad">
  <div class="landing">

    <Hero />
    <TrustBar />
    <HowItWorks />
    <FeatureGrid />

    <!-- Getting Started CTA -->
    <section class="section">
      <h2 class="section-heading">Get Started</h2>

      <div class="code-block-wrapper">
        <span class="code-block-label">bash</span>
        <pre class="code-block"><code>git clone https://github.com/swe-squad/swe-squad.git
cd swe-squad
cp .env.example .env
docker compose up -d</code></pre>
      </div>

      <a href="/docs/introduction" class="cta-button">Full Guide &rarr;</a>
    </section>

  </div>
</BaseLayout>

<style>
  :root {
    --color-bg: #ffffff;
    --color-bg-sidebar: #f9fafb;
    --color-bg-hover: rgba(0, 0, 0, 0.05);
    --color-text-primary: #1a1a2e;
    --color-text-secondary: #4a4a6a;
    --color-text-tertiary: #6b7280;
    --color-accent: #2563eb;
    --color-border: #e5e7eb;
    --section-max-width: 72rem;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    color: var(--color-text-primary);
    background-color: var(--color-bg);
    line-height: 1.6;
  }

  .landing {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: 4rem;
  }

  /* ---- Sections ---- */
  .section {
    max-width: var(--section-max-width);
    margin: 0 auto;
    padding: 2rem;
  }

  .section-heading {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-text-primary);
  }

  /* ---- Code block ---- */
  .code-block-wrapper {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .code-block-label {
    position: absolute;
    top: 0.75rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #a0a8b8;
    pointer-events: none;
  }

  .code-block {
    background: #1e1e2e;
    color: #cdd6f4;
    border-radius: 0.5rem;
    padding: 1.5rem 1.25rem;
    overflow-x: auto;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', 'Courier New', monospace;
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0;
  }

  .code-block code {
    padding: 0;
    background: none;
    color: inherit;
    font: inherit;
  }

  /* ---- CTA button ---- */
  .cta-button {
    display: inline-block;
    background: var(--color-accent);
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.0625rem;
    padding: 0.875rem 2rem;
    border-radius: 0.5rem;
    transition: background-color 0.2s, transform 0.15s;
  }

  .cta-button:hover {
    background: #2563eb;
    transform: translateY(-1px);
  }

  .cta-button:active {
    transform: translateY(0);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    thead th,
    tbody td {
      padding: 0.5rem 0.625rem;
      font-size: 0.8125rem;
    }
  }
</style>
