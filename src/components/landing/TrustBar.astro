---
/**
 * TrustBar – displays technology dependencies and license badge.
 * Static component, no props.
 */
---

<section class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-label">Built on</span>
    <div class="trust-items">
      <div class="trust-item">
        <span class="trust-icon">⚡</span>
        <span class="trust-name">Claude Code</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="trust-icon">🔗</span>
        <span class="trust-name">A2A Protocol</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="trust-icon">🗄️</span>
        <span class="trust-name">Supabase</span>
      </div>
    </div>
    <div class="trust-badge">
      <span class="badge-text">MIT License</span>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    --color-bg: #f0f4f8;
    --color-text: #1a1a2e;
    --color-text-secondary: #4a4a6a;
    --color-accent: #3b82f6;
    --color-border: #e5e7eb;
    --color-badge-bg: #ecfdf5;
    --color-badge-text: #059669;

    width: 100%;
    background-color: var(--color-bg);
  }

  .trust-bar-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .trust-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }

  .trust-items {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .trust-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .trust-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1;
  }

  .trust-divider {
    width: 1px;
    height: 1.25rem;
    background-color: var(--color-border);
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background-color: var(--color-badge-bg);
    font-size: 0.75rem;
    line-height: 1.4;
  }

  .badge-text {
    font-weight: 600;
    color: var(--color-badge-text);
  }

  @media (max-width: 640px) {
    .trust-bar-inner {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem 1.5rem;
    }

    .trust-items {
      gap: 0.75rem;
    }

    .trust-divider {
      display: none;
    }
  }
</style>
