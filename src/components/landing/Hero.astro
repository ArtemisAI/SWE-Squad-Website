---
/**
 * Hero — landing page hero section with headline, CTAs, and terminal animation.
 * Static component, no props.
 */
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <h1 class="hero-headline">Autonomous Agents That Fix Bugs While You Sleep</h1>
      <p class="hero-subheadline">
        SWE-Squad deploys coordinated AI agents that scan your repositories,
        triage issues, and ship verified fixes — all without human intervention.
      </p>
      <div class="hero-cta-group">
        <a href="/docs/introduction" class="cta-primary">Get Started</a>
        <a href="https://github.com/swe-squad/swe-squad" class="cta-outline" target="_blank" rel="noopener noreferrer">View on GitHub</a>
      </div>
    </div>

    <div class="terminal-wrapper">
      <div class="terminal">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot-red"></span>
          <span class="terminal-dot terminal-dot-yellow"></span>
          <span class="terminal-dot terminal-dot-green"></span>
          <span class="terminal-title">swe-squad</span>
        </div>
        <pre class="terminal-body"><code><span class="terminal-line" style="--line-index: 0"><span class="terminal-prompt">$</span> swe-squad scan --repo swe-squad/swe-squad</span>
<span class="terminal-line" style="--line-index: 1"><span class="terminal-tag terminal-tag-triage">[triage]</span> Classifying 3 issues... <span class="terminal-check">&check;</span> done</span>
<span class="terminal-line" style="--line-index: 2"><span class="terminal-tag terminal-tag-fix">[fix]</span>    Generating patch for #42... <span class="terminal-check">&check;</span> done</span>
<span class="terminal-line" style="--line-index: 3"><span class="terminal-tag terminal-tag-gate">[gate]</span>   All checks passed. PR created.</span></code></pre>
      </div>
    </div>
  </div>

  <!-- Bottom fade for smooth transition into lighter sections -->
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  /* ── Hero section ── */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #1e1b4b 0%, #2e1065 100%);
    overflow: hidden;
  }

  .hero-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* ── Content side ── */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-headline {
    font-size: 3.25rem;
    font-weight: 800;
    line-height: 1.1;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-subheadline {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    max-width: 32rem;
  }

  /* ── CTA buttons ── */
  .hero-cta-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.75rem;
    background: #6366f1;
    color: #ffffff;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s, transform 0.15s;
    line-height: 1.5;
  }

  .cta-primary:hover {
    background: #4f46e5;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .cta-primary:active {
    transform: translateY(0);
  }

  .cta-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.75rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
    font-size: 1rem;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s, transform 0.15s;
    line-height: 1.5;
  }

  .cta-outline:hover {
    border-color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .cta-outline:active {
    transform: translateY(0);
  }

  /* ── Terminal ── */
  .terminal-wrapper {
    display: flex;
    justify-content: center;
  }

  .terminal {
    width: 100%;
    max-width: 32rem;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .terminal-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
  }

  .terminal-dot-red {
    background: #ef4444;
  }

  .terminal-dot-yellow {
    background: #f59e0b;
  }

  .terminal-dot-green {
    background: #10b981;
  }

  .terminal-title {
    margin-left: auto;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, SF Mono, Fira Code, Fira Mono, Roboto Mono, Courier New, monospace;
  }

  .terminal-body {
    padding: 1.25rem 1.25rem 1.5rem;
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, SF Mono, Fira Code, Fira Mono, Roboto Mono, Courier New, monospace;
    font-size: 0.8125rem;
    line-height: 1.8;
    color: #cdd6f4;
    overflow-x: auto;
  }

  .terminal-body code {
    padding: 0;
    background: none;
    color: inherit;
    font: inherit;
  }

  /* ── Line-by-line typing animation ── */
  .terminal-line {
    display: block;
    opacity: 0;
    animation: terminal-reveal 0.5s ease forwards;
    animation-delay: calc(var(--line-index) * 1.2s);
  }

  .terminal-prompt {
    color: #10b981;
    margin-right: 0.5rem;
  }

  .terminal-tag {
    font-weight: 600;
    margin-right: 0.375rem;
  }

  .terminal-tag-triage {
    color: #f59e0b;
  }

  .terminal-tag-fix {
    color: #6366f1;
  }

  .terminal-tag-gate {
    color: #10b981;
  }

  .terminal-check {
    color: #10b981;
    margin: 0 0.25rem;
  }

  /* Cursor blink on last line */
  .terminal-line:last-child::after {
    content: '\2588';
    color: #cdd6f4;
    animation: cursor-blink 1s step-end infinite;
    animation-delay: calc(var(--line-index) * 1.2s + 0.5s);
    margin-left: 0.125rem;
  }

  @keyframes terminal-reveal {
    0% {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Bottom fade ── */
  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 5rem;
    background: linear-gradient(to bottom, rgba(30, 27, 75, 0), rgba(30, 27, 75, 1));
    pointer-events: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding: 3.5rem 1.5rem 3rem;
      gap: 2.5rem;
    }

    .hero-headline {
      font-size: 2.25rem;
    }

    .hero-subheadline {
      font-size: 1rem;
    }

    .hero-content {
      text-align: center;
      align-items: center;
    }

    .hero-cta-group {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-inner {
      padding: 3rem 1rem 2.5rem;
    }

    .hero-headline {
      font-size: 1.875rem;
    }

    .cta-primary,
    .cta-outline {
      width: 100%;
      justify-content: center;
    }
  }
</style>
