---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---

<nav aria-label="Filter by tag">
<div class="tag-filter">
  <a
    href="/blog"
    class:list={['tag-filter-item', { active: !activeTag }]}
  >
    All
  </a>
  {tags.map((tag) => (
    <a
      href={`/blog?tag=${tag}`}
      class:list={['tag-filter-item', { active: activeTag === tag }]}
    >
      {tag}
    </a>
  ))}
  </div>
</nav>

<style>
  .tag-filter {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .tag-filter-item {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 9999px;
    font-size: 0.8125rem;
    color: var(--color-text-secondary, #4a4a6a);
    text-decoration: none;
    background: var(--color-bg, #ffffff);
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }

  .tag-filter-item:hover {
    border-color: var(--color-accent, #3b82f6);
    color: var(--color-accent, #3b82f6);
  }

  .tag-filter-item.active {
    background: var(--color-accent, #3b82f6);
    border-color: var(--color-accent, #3b82f6);
    color: #ffffff;
  }

  .tag-filter-item:focus-visible {
    outline: 2px solid var(--color-accent, #2563eb);
    outline-offset: 2px;
  }

  @media (prefers-color-scheme: dark) {
    .tag-filter-item {
      background: var(--color-bg, #1f2937);
      border-color: var(--color-border, #374151);
      color: var(--color-text-secondary, #d1d5db);
    }

    .tag-filter-item:hover {
      border-color: var(--color-accent, #60a5fa);
      color: var(--color-accent, #60a5fa);
    }

    .tag-filter-item.active {
      background: var(--color-accent, #2563eb);
      border-color: var(--color-accent, #2563eb);
      color: #ffffff;
    }
  }
</style>
