---
interface Props {
  type?: 'info' | 'tip' | 'success' | 'warning';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const colorMap: Record<string, { accent: string; bg: string; darkAccent: string; darkBg: string }> = {
  info:    { accent: '#1e40af', bg: 'rgba(59, 130, 246, 0.08)', darkAccent: '#93c5fd', darkBg: 'rgba(59, 130, 246, 0.18)' },
  tip:     { accent: '#5b21b6', bg: 'rgba(139, 92, 246, 0.08)', darkAccent: '#c4b5fd', darkBg: 'rgba(139, 92, 246, 0.18)' },
  success: { accent: '#15803d', bg: 'rgba(34, 197, 94, 0.08)', darkAccent: '#86efac', darkBg: 'rgba(34, 197, 94, 0.18)' },
  warning: { accent: '#92400e', bg: 'rgba(245, 158, 11, 0.08)', darkAccent: '#fcd34d', darkBg: 'rgba(245, 158, 11, 0.18)' },
};

const colors = colorMap[type];
---

<div class="callout" role="note" style={`--callout-accent: ${colors.accent}; --callout-bg: ${colors.bg}; --callout-dark-accent: ${colors.darkAccent}; --callout-dark-bg: ${colors.darkBg};`}>
  {title && <div class="callout-title">{title}</div>}
  <div class="callout-content">
    <slot />
  </div>
</div>

<style>
  .callout {
    background: var(--callout-bg);
    border-left: 4px solid var(--callout-accent);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--color-text, inherit);
  }

  .callout-title {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--callout-accent);
  }

  .callout-content {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .callout-content :global(p) {
    margin: 0;
  }

  .callout-content :global(p + p) {
    margin-top: 0.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .callout {
      background: var(--callout-dark-bg);
      border-left-color: var(--callout-dark-accent);
    }

    .callout-title {
      color: var(--callout-dark-accent);
    }
  }
</style>
