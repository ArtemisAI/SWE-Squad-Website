---
---

<div class="search-backdrop" id="search-backdrop"></div>
<div class="search-dialog" id="search-dialog" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-input-wrapper">
    <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M8.5 3a5.5 5.5 0 0 1 4.23 9.02l4.12 4.13a.75.75 0 0 1-1.06 1.06l-4.13-4.12A5.5 5.5 0 1 1 8.5 3zm0 1.5a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" fill="currentColor"/>
    </svg>
    <input
      type="search"
      class="search-input"
      id="search-input"
      placeholder="Search docs and blog..."
      autocomplete="off"
      autofocus
      aria-label="Search documentation"
    />
    <kbd class="search-kbd">Esc</kbd>
  </div>
  <div class="search-results" id="search-results">
    <div class="search-empty">Type to search documentation and blog posts</div>
  </div>
</div>

<style>
  .search-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 50;
  }

  .search-backdrop.is-open {
    display: block;
  }

  .search-dialog {
    display: none;
    position: fixed;
    top: 12vh;
    left: 50%;
    transform: translateX(-50%);
    width: min(90vw, 40rem);
    max-height: 70vh;
    background: var(--color-bg, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.75rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    z-index: 51;
    overflow: hidden;
    display: none;
    flex-direction: column;
  }

  .search-dialog.is-open {
    display: flex;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .search-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary, #6b7280);
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text-primary, #1a1a2e);
    background: transparent;
  }

  .search-input:focus-visible {
    outline: 2px solid var(--color-accent, #2563eb);
    outline-offset: 2px;
  }

  .search-input::placeholder {
    color: var(--color-text-tertiary, #6b7280);
  }

  .search-kbd {
    flex-shrink: 0;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-family: inherit;
    color: var(--color-text-tertiary, #6b7280);
    background: var(--color-bg-sidebar, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.25rem;
  }

  .search-results {
    overflow-y: auto;
    padding: 0.5rem 0;
    max-height: calc(70vh - 4rem);
  }

  .search-empty {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-text-tertiary, #6b7280);
    font-size: 0.875rem;
  }

  .search-no-results {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-text-tertiary, #6b7280);
    font-size: 0.875rem;
  }
</style>

<script>
  function initSearch() {
    const backdrop = document.getElementById('search-backdrop');
    const dialog = document.getElementById('search-dialog');
    const input = document.getElementById('search-input') as HTMLInputElement;
    const resultsContainer = document.getElementById('search-results');

    let pagefindLoaded = false;

    async function ensurePagefindLoaded() {
      if (pagefindLoaded) return;
      await loadPagefind();
      pagefindLoaded = true;
    }

    function openSearch() {
      backdrop?.classList.add('is-open');
      dialog?.classList.add('is-open');
      input?.focus();
      document.body.style.overflow = 'hidden';
      ensurePagefindLoaded().catch(() => {
        // Pagefind not available (dev mode or before first build)
      });
    }

    function trapFocus(e: KeyboardEvent) {
      if (e.key !== 'Tab') return;
      if (!dialog) return;

      const focusableSelectors = 'a[href], input, button, textarea, select, [tabindex]:not([tabindex="-1"])';
      const focusableEls = dialog.querySelectorAll<HTMLElement>(focusableSelectors);
      if (focusableEls.length === 0) return;

      const firstEl = focusableEls[0];
      const lastEl = focusableEls[focusableEls.length - 1];

      if (e.shiftKey) {
        if (document.activeElement === firstEl) {
          e.preventDefault();
          lastEl.focus();
        }
      } else {
        if (document.activeElement === lastEl) {
          e.preventDefault();
          firstEl.focus();
        }
      }
    }

    dialog?.addEventListener('keydown', trapFocus);

    function closeSearch() {
      backdrop?.classList.remove('is-open');
      dialog?.classList.remove('is-open');
      document.body.style.overflow = '';
      if (input) input.value = '';
      if (resultsContainer) {
        resultsContainer.innerHTML = '<div class="search-empty">Type to search documentation and blog posts</div>';
      }
      document.querySelector('[aria-label="Search documentation"]')?.focus();
    }

    // Cmd+K / Ctrl+K shortcut
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (dialog?.classList.contains('is-open')) {
          closeSearch();
        } else {
          openSearch();
        }
      }
      if (e.key === 'Escape' && dialog?.classList.contains('is-open')) {
        closeSearch();
      }
    });

    backdrop?.addEventListener('click', closeSearch);

    // Load Pagefind and wire up search
    async function loadPagefind() {
      // @ts-ignore - Pagefind is generated at build time
      const pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();

      input?.addEventListener('input', async () => {
        const query = input.value.trim();
        if (!query) {
          if (resultsContainer) {
            resultsContainer.innerHTML = '<div class="search-empty">Type to search documentation and blog posts</div>';
          }
          return;
        }

        const search = await pagefind.search(query);
        const results = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

        if (results.length === 0) {
          if (resultsContainer) {
            resultsContainer.innerHTML = `<div class="search-no-results">No results for "${query}"</div>`;
          }
          return;
        }

        if (resultsContainer) {
          resultsContainer.innerHTML = results.map((result: any) => {
            const url = result.url;
            const title = result.meta?.title || url;
            const excerpt = result.excerpt || '';
            return `
              <a href="${url}" class="search-result">
                <div class="search-result-title">${title}</div>
                <div class="search-result-excerpt">${excerpt}</div>
              </a>
            `;
          }).join('');
        }
      });
    }
  }

  initSearch();
</script>

<style is:global>
  .search-result {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .search-result:hover,
  .search-result:focus {
    background: var(--color-bg-hover, rgba(0, 0, 0, 0.05));
  }

  .search-result-title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text-primary, #1a1a2e);
    margin-bottom: 0.25rem;
  }

  .search-result-excerpt {
    font-size: 0.8125rem;
    color: var(--color-text-secondary, #4a4a6a);
    line-height: 1.5;
  }

  .search-result-excerpt mark {
    background: rgba(59, 130, 246, 0.15);
    color: var(--color-accent, #3b82f6);
    padding: 0.0625rem 0;
    border-radius: 0.125rem;
  }
</style>
