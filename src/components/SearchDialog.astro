---
---

<div class="search-backdrop" id="search-backdrop"></div>
<div class="search-dialog" id="search-dialog" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-input-wrapper">
    <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M8.5 3a5.5 5.5 0 0 1 4.23 9.02l4.12 4.13a.75.75 0 0 1-1.06 1.06l-4.13-4.12A5.5 5.5 0 1 1 8.5 3zm0 1.5a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" fill="currentColor"/>
    </svg>
    <input
      type="search"
      class="search-input"
      id="search-input"
      placeholder="Search docs and blog..."
      autocomplete="off"
      autofocus
    />
    <kbd class="search-kbd">Esc</kbd>
  </div>
  <div class="search-results" id="search-results">
    <div class="search-empty">Type to search documentation and blog posts</div>
  </div>
</div>

<style>
  .search-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 50;
  }

  .search-backdrop.is-open {
    display: block;
  }

  .search-dialog {
    display: none;
    position: fixed;
    top: 12vh;
    left: 50%;
    transform: translateX(-50%);
    width: min(90vw, 40rem);
    max-height: 70vh;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    z-index: 51;
    overflow: hidden;
    flex-direction: column;
  }

  .dark .search-dialog {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
  }

  .search-dialog.is-open {
    display: flex;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text-primary);
    background: transparent;
  }

  .search-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .search-kbd {
    flex-shrink: 0;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-family: inherit;
    color: var(--color-text-tertiary);
    background: var(--color-bg-sidebar);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
  }

  .search-results {
    overflow-y: auto;
    padding: 0.5rem 0;
    max-height: calc(70vh - 4rem);
  }

  .search-empty {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
  }

  .search-no-results {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
  }

  .search-loading {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
  }
</style>

<script>
  function initSearch() {
    const backdrop = document.getElementById('search-backdrop');
    const dialog = document.getElementById('search-dialog');
    const input = document.getElementById('search-input') as HTMLInputElement;
    const resultsContainer = document.getElementById('search-results');

    let pagefindLoaded = false;
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    let activeIndex = -1;

    async function ensurePagefindLoaded() {
      if (pagefindLoaded) return;
      await loadPagefind();
      pagefindLoaded = true;
    }

    function openSearch() {
      backdrop?.classList.add('is-open');
      dialog?.classList.add('is-open');
      input?.focus();
      document.body.style.overflow = 'hidden';
      ensurePagefindLoaded().catch(() => {});
    }

    function closeSearch() {
      backdrop?.classList.remove('is-open');
      dialog?.classList.remove('is-open');
      document.body.style.overflow = '';
      if (input) input.value = '';
      activeIndex = -1;
      if (resultsContainer) {
        resultsContainer.innerHTML = '<div class="search-empty">Type to search documentation and blog posts</div>';
      }
    }

    function updateActiveResult(index: number) {
      const items = resultsContainer?.querySelectorAll('.search-result');
      if (!items || items.length === 0) return;

      items.forEach((item) => item.classList.remove('is-active'));

      if (index >= 0 && index < items.length) {
        items[index].classList.add('is-active');
        (items[index] as HTMLElement).scrollIntoView({ block: 'nearest' });
      }
    }

    // Cmd+K / Ctrl+K shortcut
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (dialog?.classList.contains('is-open')) {
          closeSearch();
        } else {
          openSearch();
        }
      }
      if (e.key === 'Escape' && dialog?.classList.contains('is-open')) {
        closeSearch();
      }

      // Arrow key navigation within results
      if (dialog?.classList.contains('is-open') && resultsContainer) {
        const items = resultsContainer.querySelectorAll('.search-result');
        if (items.length === 0) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = Math.min(activeIndex + 1, items.length - 1);
          updateActiveResult(activeIndex);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = Math.max(activeIndex - 1, -1);
          updateActiveResult(activeIndex);
        } else if (e.key === 'Enter' && activeIndex >= 0 && activeIndex < items.length) {
          e.preventDefault();
          (items[activeIndex] as HTMLAnchorElement).click();
        }
      }
    });

    backdrop?.addEventListener('click', closeSearch);

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getResultPath(url: string): string {
      if (url.startsWith('/docs/')) return 'Docs';
      if (url.startsWith('/blog/')) return 'Blog';
      return '';
    }

    // Load Pagefind and wire up search
    async function loadPagefind() {
      // @ts-ignore - Pagefind is generated at build time
      const pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();

      input?.addEventListener('input', () => {
        const query = input.value.trim();

        if (debounceTimer) clearTimeout(debounceTimer);

        if (!query) {
          activeIndex = -1;
          if (resultsContainer) {
            resultsContainer.innerHTML = '<div class="search-empty">Type to search documentation and blog posts</div>';
          }
          return;
        }

        if (resultsContainer) {
          resultsContainer.innerHTML = '<div class="search-loading">Searching...</div>';
        }

        debounceTimer = setTimeout(async () => {
          const search = await pagefind.search(query);
          const results = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

          if (results.length === 0) {
            if (resultsContainer) {
              resultsContainer.innerHTML = `<div class="search-no-results">No results for "${escapeHtml(query)}"</div>`;
            }
            activeIndex = -1;
            return;
          }

          if (resultsContainer) {
            resultsContainer.innerHTML = results.map((result: any) => {
              const url = result.url;
              const title = result.meta?.title || url;
              const excerpt = result.excerpt || '';
              const pathLabel = getResultPath(url);
              return `
                <a href="${url}" class="search-result">
                  <div class="search-result-header">
                    <span class="search-result-title">${escapeHtml(title)}</span>
                    ${pathLabel ? `<span class="search-result-path">${pathLabel}</span>` : ''}
                  </div>
                  <div class="search-result-excerpt">${excerpt}</div>
                </a>
              `;
            }).join('');
            activeIndex = -1;
          }
        }, 200);
      });
    }
  }

  initSearch();
</script>

<style is:global>
  .search-result {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .search-result:hover,
  .search-result:focus {
    background: var(--color-bg-hover);
  }

  .search-result.is-active {
    background: var(--color-bg-hover);
  }

  .search-result-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .search-result-title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
  }

  .search-result-path {
    flex-shrink: 0;
    padding: 0.0625rem 0.375rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-tertiary);
    background: var(--color-bg-sidebar);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    line-height: 1.4;
  }

  .dark .search-result-path {
    background: var(--color-bg-hover);
  }

  .search-result-excerpt {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .search-result-excerpt mark {
    background: rgba(99, 102, 241, 0.15);
    color: var(--color-accent);
    padding: 0.0625rem 0;
    border-radius: 0.125rem;
  }
</style>
