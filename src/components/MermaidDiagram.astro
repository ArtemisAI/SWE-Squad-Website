---
interface Props {
  code: string;
  id?: string;
  theme?: string;
}

const { code, id, theme = 'default' } = Astro.props;
const diagramId = id ?? `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<pre class="mermaid" role="img" aria-label={`Diagram: ${code.substring(0, 100)}`} data-mermaid-id={diagramId} data-mermaid-theme={theme}>{code}</pre>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const mermaidEls = document.querySelectorAll('.mermaid');
    if (mermaidEls.length === 0) return;
    const { default: mermaid } = await import('mermaid');
    mermaid.initialize({ startOnLoad: false, theme: 'default' });
    requestIdleCallback(() => {
      mermaid.run({ querySelector: '.mermaid' });
    }, { timeout: 2000 });
  });
</script>

<style>
  .mermaid {
    background: var(--color-bg-sidebar, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    font-family: inherit;
    line-height: 1.5;
    margin: 1.5rem 0;
  }
</style>
