---
import { renderMermaidDiagram } from '../utils/renderMermaid.mjs';

interface Props {
  code: string;
  id?: string;
  theme?: string;
}

const { code, id, theme = 'default' } = Astro.props;
const diagramId = id ?? `mermaid-${Math.random().toString(36).slice(2, 9)}`;
const svg = await renderMermaidDiagram(code);
---

<div class="mermaid" data-mermaid-id={diagramId} data-mermaid-theme={theme} set:html={svg} />

<style>
  .mermaid {
    background: var(--color-bg-sidebar, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    font-family: inherit;
    line-height: 1.5;
    margin: 1.5rem 0;
  }
</style>
