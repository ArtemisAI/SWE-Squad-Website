---
interface Props {
  code: string;
  id?: string;
  theme?: string;
  diagramDescription?: string;
}

const { code, id, theme = 'default' } = Astro.props;
const diagramId = id ?? `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<pre class="mermaid" role="img" aria-label={diagramDescription || "Diagram: see text description below"} data-mermaid-id={diagramId} data-mermaid-theme={theme}>{code}</pre>
<p class="sr-only">{diagramDescription || "Visual diagram - see surrounding text for description"}</p>

<script>
  import mermaid from 'mermaid';

  mermaid.initialize({ startOnLoad: false, theme: 'default' });

  document.addEventListener('DOMContentLoaded', () => {
    mermaid.run({ querySelector: '.mermaid' });
  });
</script>

<style>
  .mermaid {
    background: var(--color-bg-sidebar, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    font-family: inherit;
    line-height: 1.5;
    margin: 1.5rem 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
