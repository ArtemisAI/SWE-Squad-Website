---
/**
 * Header — sticky, responsive site header with dark mode toggle and mobile drawer.
 *
 * Props: none (self-contained)
 * Dependencies: Tailwind CSS 3 (darkMode: 'class'), global.css custom properties
 */

const navLinks = [
  { label: 'Features', href: '/features' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'Docs', href: '/docs' },
  { label: 'Blog', href: '/blog' },
  { label: 'Community', href: '/community' },
  { label: 'GitHub', href: 'https://github.com/swe-squad', external: true },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-gray-200/80 transition-colors duration-300 dark:border-gray-700/60"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5 no-underline" aria-label="SWE-Squad home">
      <svg
        class="h-8 w-7 shrink-0 text-primary-500 transition-transform duration-200 group-hover:scale-105"
        viewBox="0 0 28 32"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M14 0L0 7v8c0 8.8 6 17 14 18 8-1 14-9.2 14-18V7L14 0z"
          fill="currentColor"
        />
        <path
          d="M14 3L3 8.5v6.5c0 7.2 4.8 13.8 11 14.8 6.2-1 11-7.6 11-14.8V8.5L14 3z"
          fill="var(--color-bg, #ffffff)"
          opacity="0.92"
        />
        <path
          d="M10 16l3 3 5-6"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </svg>
      <span class="text-lg font-bold tracking-tight text-gray-900 dark:text-white">
        SWE-Squad
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
      {navLinks.map(({ label, href, external }) => {
        const isActive = !external && (currentPath === href || (href !== '/' && currentPath.startsWith(href)));
        return (
          <a
            href={href}
            class:list={[
              'inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-sm font-medium transition-colors duration-150 no-underline',
              isActive
                ? 'bg-primary-50 text-primary-700 dark:bg-primary-900/40 dark:text-primary-300'
                : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
            ]}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
          >
            {label}
            {external && (
              <svg
                class="h-3.5 w-3.5 opacity-60"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M6.28 5.22a.75.75 0 00-1.06 1.06L12.94 14H7.75a.75.75 0 000 1.5h7.5a.75.75 0 00.75-.75v-7.5a.75.75 0 00-1.5 0v5.19L6.28 5.22z"
                />
              </svg>
            )}
          </a>
        );
      })}
    </nav>

    <!-- Right-side controls -->
    <div class="flex items-center gap-2">
      <!-- Search button -->
      <button
        id="header-search-trigger"
        type="button"
        class="hidden h-9 items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm text-gray-400 transition-colors duration-200 hover:border-primary-300 hover:text-gray-600 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-500 dark:hover:border-gray-600 dark:hover:text-gray-300 md:inline-flex"
        aria-label="Search docs and blog"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M8.5 3a5.5 5.5 0 0 1 4.23 9.02l4.12 4.13a.75.75 0 0 1-1.06 1.06l-4.13-4.12A5.5 5.5 0 1 1 8.5 3zm0 1.5a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" fill="currentColor"/>
        </svg>
        <span>Search...</span>
        <kbd class="ml-4 inline-block rounded border border-gray-200 px-1.5 py-0.5 font-mono text-[0.625rem] leading-none text-gray-400 dark:border-gray-600 dark:text-gray-500">⌘K</kbd>
      </button>

      <!-- Dark / Light toggle -->
      <button
        id="theme-toggle"
        type="button"
        class="relative inline-flex h-9 w-9 items-center justify-center rounded-lg text-gray-500 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          class="sun-icon h-5 w-5 hidden dark:block"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6zM17.48 10a.75.75 0 01.75.75v.01a.75.75 0 01-.75.75h-.01a.75.75 0 01-.75-.75v-.01a.75.75 0 01.75-.75h.01zM2.52 10a.75.75 0 01.75.75v.01a.75.75 0 01-.75.75h-.01a.75.75 0 01-.75-.75v-.01a.75.75 0 01.75-.75h.01zM15.3 4.7a.75.75 0 010 1.06l-.354.353a.75.75 0 01-1.06-1.06l.353-.354a.75.75 0 011.061 0zM5.05 14.95a.75.75 0 010 1.06l-.354.353a.75.75 0 01-1.06-1.06l.354-.354a.75.75 0 011.06 0zM14.95 14.95a.75.75 0 011.06 0l.354.354a.75.75 0 01-1.06 1.06l-.354-.353a.75.75 0 010-1.06zM4.7 4.7a.75.75 0 011.06 0l.354.354a.75.75 0 01-1.06 1.06L4.7 5.76a.75.75 0 010-1.06z"
          />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          class="moon-icon h-5 w-5 block dark:hidden"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M17.293 13.293A8 8 0 016.707 2.707a8.003 8.003 0 1010.586 10.586z"
          />
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-open"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-gray-500 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white md:hidden"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer overlay + panel -->
  <div
    id="mobile-drawer"
    class="fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
  >
    <!-- Overlay -->
    <div
      id="mobile-drawer-overlay"
      class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-300"
    ></div>

    <!-- Panel -->
    <div
      id="mobile-drawer-panel"
      class="absolute inset-y-0 right-0 flex w-full max-w-xs flex-col bg-white shadow-xl transition-transform duration-300 dark:bg-gray-900 translate-x-full"
    >
      <!-- Drawer header -->
      <div class="flex h-16 items-center justify-between border-b border-gray-200 px-4 dark:border-gray-700">
        <span class="text-lg font-bold tracking-tight text-gray-900 dark:text-white">Menu</span>
        <button
          id="mobile-menu-close"
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-gray-500 transition-colors duration-200 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white"
          aria-label="Close navigation menu"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <!-- Drawer nav links -->
      <nav class="flex-1 overflow-y-auto px-4 py-4" aria-label="Mobile navigation">
        <ul class="space-y-1">
          {navLinks.map(({ label, href, external }) => {
            const isActive = !external && (currentPath === href || (href !== '/' && currentPath.startsWith(href)));
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'flex items-center gap-2 rounded-lg px-3 py-2.5 text-base font-medium no-underline transition-colors duration-150',
                    isActive
                      ? 'bg-primary-50 text-primary-700 dark:bg-primary-900/40 dark:text-primary-300'
                      : 'text-gray-700 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
                  ]}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                  data-mobile-link
                >
                  {label}
                  {external && (
                    <svg
                      class="h-4 w-4 opacity-60"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L12.94 14H7.75a.75.75 0 000 1.5h7.5a.75.75 0 00.75-.75v-7.5a.75.75 0 00-1.5 0v5.19L6.28 5.22z" />
                    </svg>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- Drawer footer: theme toggle -->
      <div class="border-t border-gray-200 px-4 py-4 dark:border-gray-700">
        <button
          id="mobile-theme-toggle"
          type="button"
          class="flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-base font-medium text-gray-700 transition-colors duration-150 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white"
          aria-label="Toggle dark mode"
        >
          <svg
            class="mobile-sun-icon h-5 w-5 hidden dark:block"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6zM17.48 10a.75.75 0 01.75.75v.01a.75.75 0 01-.75.75h-.01a.75.75 0 01-.75-.75v-.01a.75.75 0 01.75-.75h.01zM2.52 10a.75.75 0 01.75.75v.01a.75.75 0 01-.75.75h-.01a.75.75 0 01-.75-.75v-.01a.75.75 0 01.75-.75h.01zM15.3 4.7a.75.75 0 010 1.06l-.354.353a.75.75 0 01-1.06-1.06l.353-.354a.75.75 0 011.061 0zM5.05 14.95a.75.75 0 010 1.06l-.354.353a.75.75 0 01-1.06-1.06l.354-.354a.75.75 0 011.06 0zM14.95 14.95a.75.75 0 011.06 0l.354.354a.75.75 0 01-1.06 1.06l-.354-.353a.75.75 0 010-1.06zM4.7 4.7a.75.75 0 011.06 0l.354.354a.75.75 0 01-1.06 1.06L4.7 5.76a.75.75 0 010-1.06z" />
          </svg>
          <svg
            class="mobile-moon-icon h-5 w-5 block dark:hidden"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.003 8.003 0 1010.586 10.586z" />
          </svg>
          <span class="mobile-theme-label dark:hidden">Switch to dark mode</span>
          <span class="mobile-theme-label hidden dark:inline">Switch to light mode</span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  // ── Theme toggle ──────────────────────────────────────────────────────────
  const THEME_KEY = 'theme';

  function getSystemPreference(): 'dark' | 'light' {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(theme: 'dark' | 'light') {
    const root = document.documentElement;
    if (theme === 'dark') {
      root.classList.add('dark');
    } else {
      root.classList.remove('dark');
    }
  }

  function getStoredTheme(): 'dark' | 'light' | null {
    const stored = localStorage.getItem(THEME_KEY);
    if (stored === 'dark' || stored === 'light') return stored;
    return null;
  }

  function toggleTheme() {
    const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    applyTheme(next);
    localStorage.setItem(THEME_KEY, next);
  }

  // Initialize from stored preference (layouts may also have a FOUC-prevention
  // script, but this ensures the toggle state stays consistent on navigation).
  const stored = getStoredTheme();
  if (stored) {
    applyTheme(stored);
  } else {
    applyTheme(getSystemPreference());
  }

  // Desktop toggle
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);

  // Mobile toggle
  document.getElementById('mobile-theme-toggle')?.addEventListener('click', toggleTheme);

  // ── Header search trigger ──────────────────────────────────────────────────
  document.getElementById('header-search-trigger')?.addEventListener('click', () => {
    const searchBackdrop = document.getElementById('search-backdrop');
    const searchDialog = document.getElementById('search-dialog');
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    searchBackdrop?.classList.add('is-open');
    searchDialog?.classList.add('is-open');
    searchInput?.focus();
    document.body.style.overflow = 'hidden';
  });

  // ── Mobile drawer ─────────────────────────────────────────────────────────
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('mobile-drawer-overlay');
  const panel = document.getElementById('mobile-drawer-panel');
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');

  let drawerOpen = false;

  function openDrawer() {
    if (!drawer || !panel) return;
    drawerOpen = true;
    drawer.classList.remove('hidden');
    // Force reflow before adding transition class so the slide-in animates
    void drawer.offsetHeight;
    panel.classList.remove('translate-x-full');
    panel.classList.add('translate-x-0');
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    if (!drawer || !panel) return;
    drawerOpen = false;
    panel.classList.remove('translate-x-0');
    panel.classList.add('translate-x-full');
    openBtn?.setAttribute('aria-expanded', 'false');

    // Wait for transition to finish before hiding
    const onTransitionEnd = () => {
      if (!drawerOpen) {
        drawer.classList.add('hidden');
      }
      panel?.removeEventListener('transitionend', onTransitionEnd);
    };
    panel.addEventListener('transitionend', onTransitionEnd);

    // Fallback: hide after 350ms in case transitionend doesn't fire
    setTimeout(() => {
      if (!drawerOpen) {
        drawer.classList.add('hidden');
      }
    }, 350);

    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  // Close drawer when pressing Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawerOpen) {
      closeDrawer();
    }
  });

  // Close drawer when a mobile nav link is clicked (helps SPA-like feel)
  document.querySelectorAll('[data-mobile-link]').forEach((link) => {
    link.addEventListener('click', () => {
      closeDrawer();
    });
  });

  // ── Scroll-based backdrop effect ──────────────────────────────────────────
  const header = document.getElementById('site-header');

  function updateHeaderBackdrop() {
    if (!header) return;
    if (window.scrollY > 10) {
      header.classList.add('backdrop-blur-md', 'bg-white/80', 'dark:bg-gray-900/80');
      header.classList.remove('bg-white', 'dark:bg-gray-900');
    } else {
      header.classList.remove('backdrop-blur-md', 'bg-white/80', 'dark:bg-gray-900/80');
      header.classList.add('bg-white', 'dark:bg-gray-900');
    }
  }

  // Set initial state
  updateHeaderBackdrop();

  window.addEventListener('scroll', updateHeaderBackdrop, { passive: true });
</script>
